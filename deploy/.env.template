# ============================================================
# 企业AI知识库系统 — 环境配置模板
# 复制为 .env 后根据实际情况填写
# ============================================================

# ── 服务器访问地址 ────────────────────────────────────────
# 浏览器访问地址（IP 或 域名，不含端口和路径）
SERVER_HOST=192.168.1.100
# 对外端口（默认80，如使用其他端口如 8080 需同步修改）
HTTP_PORT=80

# ── MySQL ────────────────────────────────────────────────
# 以下两个密码会在安装时自动生成，也可手动填写
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=kb_user
MYSQL_PASSWORD=CHANGE_ME_APP
MYSQL_DATABASE=knowledge_base

# ── 安全密钥（安装时自动生成，请勿手动修改） ──────────────
SECRET_KEY=CHANGE_ME_64HEX
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── MeiliSearch 全文搜索 ──────────────────────────────────
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=CHANGE_ME_MEILI

# ── Milvus 向量数据库 ─────────────────────────────────────
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION=document_chunks

# ── MinIO 对象存储 ────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_USER
MINIO_SECRET_KEY=CHANGE_ME_MINIO_PASS
MINIO_BUCKET=knowledge-base
MINIO_SECURE=false

# ── 宿主机目录（docker-compose volume 挂载源） ────────────
HOST_UPLOAD_DIR=/data/kb/uploads     # 上传文件存储目录
HOST_WATCH_DIR=/data/kb/watch        # 目录监控（如 NAS 挂载点）
HOST_MODEL_DIR=/data/kb/models       # 存放 bge-m3、bge-reranker 等模型

# ── 容器内路径（后端应用读取，勿随意修改） ────────────────
UPLOAD_DIR=/app/uploads
WATCH_DIR=/mnt/nas
WATCH_SCAN_INTERVAL_SECONDS=300

# ── Embedding / Reranker 模型路径（容器内路径） ────────────
EMBEDDING_MODEL=/models/bge-m3
RERANKER_MODEL=/models/bge-reranker-v2-m3
EMBEDDING_DEVICE=cpu        # 有 GPU 改为 cuda
EMBEDDING_BATCH_SIZE=32

# ── LLM 配置 ──────────────────────────────────────────────
# 方案一：外部 API（DeepSeek / OpenAI 等）
LLM_API_BASE=https://api.deepseek.com/v1
LLM_API_KEY=sk-YOUR_KEY_HERE
LLM_MODEL=deepseek-chat

# 方案二：本地 Ollama（取消注释并注释上方三行）
# LLM_API_BASE=http://host.docker.internal:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen2.5:7b

# ── Vision 多模态（可选，用于图片/图表分析） ──────────────
VISION_API_BASE=https://ark.volces.com/api/v3
VISION_API_KEY=
VISION_MODEL=doubao-seed-1.6

# ── OCR ──────────────────────────────────────────────────
OCR_LANG=ch
OCR_USE_GPU=false

# ── RAG 检索参数 ──────────────────────────────────────────
RAG_RETRIEVE_TOP_K=5

# ── CORS ─────────────────────────────────────────────────
# 生产环境建议改为具体域名，如 https://kb.company.com
CORS_ORIGINS=*

# ── Celery ───────────────────────────────────────────────
CELERY_BROKER_CONNECTION_RETRY_ON_STARTUP=true
